# =============================================================================
# Next.js — copy to `.env.local` in this folder (frontend/)
#   copy .env.example .env.local
# Loaded automatically by `next dev` / build. See Next.js env docs.
# =============================================================================

# Proxy FastAPI when running `npm run dev` (browser calls same-origin /api/*)
BACKEND_PROXY_URL=http://127.0.0.1:8000

# Public URL prefix for API (production behind Nginx often `/api`)
NEXT_PUBLIC_API_URL=/api

# Match backend SAAS_REQUIRE_AUTH when using accounts
NEXT_PUBLIC_SAAS_REQUIRE_AUTH=false

# =============================================================================
# Future (optional — add when you implement these features)
# =============================================================================
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
