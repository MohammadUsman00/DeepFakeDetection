# =============================================================================
# DeepShield — environment template
# Copy to `.env` in the repository root (same folder as docker-compose.yml):
#   copy .env.example .env   (Windows PowerShell / CMD)
#   cp .env.example .env      (macOS / Linux)
# Never commit `.env`; it is listed in `.gitignore`.
# =============================================================================

# --- Database (set for Postgres; omit for SQLite local dev) ---
DATABASE_URL=postgresql://deepshield:deepshield_secure_pw@localhost:5432/deepshield

# --- Celery / Redis (queue + optional Socket.IO Redis adapter) ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Storage ---
STORAGE_DATA_DIR=./data

# --- SaaS / JWT (see docs/SAAS.md) ---
SAAS_REQUIRE_AUTH=false
SAAS_JWT_SECRET=dev-only-change-in-production-use-long-random-string
SAAS_JWT_EXP_HOURS=168
SAAS_FREE_DAILY_UPLOADS=20

# --- Inference ---
INFER_MODEL_WEIGHTS_PATH=./data/models/efficientnet_b0.pth
# p_fake >= threshold => predicted_manipulation true (when not low-confidence); tune on validation data
INFER_FAKE_DECISION_THRESHOLD=0.5

# --- API tuning (optional) ---
RATE_LIMIT_RPS=0
RATE_LIMIT_BURST=30
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- File / video limits (optional; defaults in backend/app/config.py) ---
# FILE_MAX_UPLOAD_MB=200
# VIDEO_MAX_DURATION_SECONDS=180
# VIDEO_MAX_FRAMES=150

# =============================================================================
# Future integrations (not wired in code yet — placeholders for roadmap)
# =============================================================================
# Stripe / billing
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO=

# Google OAuth (sign-in with Google — not implemented yet)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8001/api/auth/google/callback

# Email (verification / password reset — not implemented yet)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=noreply@example.com
